<!-- Floating back-to-top button -->
<button
  id="back-to-top"
  type="button"
  aria-label="Back to top"
  class="fixed bottom-6 left-6 z-50 w-12 h-12 rounded-full flex items-center justify-center text-forest-700 hover:text-forest-600 transition-all float-shadow opacity-0 translate-y-2 pointer-events-none"
  style="background:rgba(255,255,255,0.9);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.5);"
>
  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" />
  </svg>
</button>

<script is:inline>
  (function() {
    var btn = document.getElementById('back-to-top');
    if (!btn) return;
    function toggle() {
      if (window.scrollY > 400) {
        btn.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
      } else {
        btn.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
      }
    }
    window.addEventListener('scroll', toggle, { passive: true });
    btn.addEventListener('click', function() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    toggle();
  })();
</script>

