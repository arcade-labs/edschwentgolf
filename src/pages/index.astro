---
import Layout from '../layouts/Layout.astro';

// Gallery images: add as many as Ed has, slider handles any count
// Every photo uses object-cover so any aspect ratio looks perfect
const galleryImages = [
  // { src: '/images/gallery/1.jpg', alt: 'Ed teaching on the range' },
  // { src: '/images/gallery/2.jpg', alt: 'Swing analysis session' },
  // { src: '/images/gallery/3.jpg', alt: 'Old Hickory course view' },
];
---

<Layout
  title="Ed Schwent Golf - Lessons & Instruction in St. Louis"
  description="Book golf lessons with Ed Schwent, Gateway PGA Teacher of the Year and Golf Digest top-ranked instructor in Missouri. Located at Old Hickory Golf Club, St. Peters, MO."
>
  <style is:global>
    .glass {
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.3);
    }
    .glass-card {
      background: rgba(255, 255, 255, 0.55);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.5);
      box-shadow: 0 8px 32px rgba(0,0,0,0.06), inset 0 1px 0 rgba(255,255,255,0.7);
    }
    .text-gradient {
      background: linear-gradient(135deg, #15803d 0%, #16a34a 50%, #14532d 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .btn-gradient {
      background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
    }
    .btn-gradient:hover {
      background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    }
    .float-shadow {
      box-shadow: 0 20px 60px rgba(0,0,0,0.08), 0 8px 24px rgba(0,0,0,0.04);
    }
    .card {
      background: white;
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: 24px;
      transition: all 0.3s ease;
    }
    .card:hover {
      box-shadow: 0 12px 40px rgba(0,0,0,0.08);
      transform: translateY(-2px);
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    .animate-float { animation: float 6s ease-in-out infinite; }

    /* Slider */
    .slider-track {
      display: flex;
      gap: 16px;
      transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
      cursor: grab;
      user-select: none;
    }
    .slider-track:active { cursor: grabbing; transition: none; }
    .slider-track img { -webkit-user-drag: none; user-select: none; pointer-events: none; }
    .slider-slide {
      flex-shrink: 0;
      width: 400px;
      height: 300px;
      border-radius: 20px;
      overflow: hidden;
    }
    @media (max-width: 640px) {
      .slider-slide { width: 300px; height: 225px; }
    }
    .slider-slide img { width: 100%; height: 100%; object-fit: cover; }
  </style>

  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-4">
      <div class="glass rounded-2xl px-6 py-3 flex items-center justify-between">
        <a href="#" class="font-display text-xl tracking-tight text-forest-900">
          <span class="font-bold">Ed Schwent</span> <span class="text-forest-600 font-bold">Golf</span>
        </a>
        <div class="hidden md:flex items-center gap-8">
          <a href="#about" class="text-sm font-medium text-gray-600 hover:text-forest-600 transition-colors">About</a>
          <a href="#method" class="text-sm font-medium text-gray-600 hover:text-forest-600 transition-colors">Method</a>
          {galleryImages.length > 0 && (
            <a href="#gallery" class="text-sm font-medium text-gray-600 hover:text-forest-600 transition-colors">Gallery</a>
          )}
          <a href="#book" class="text-sm font-medium text-gray-600 hover:text-forest-600 transition-colors">Book</a>
        </div>
        <a
          href="#book"
          class="inline-flex items-center rounded-xl btn-gradient px-5 py-2.5 text-sm font-semibold text-white transition-all hover:shadow-lg hover:shadow-forest-600/25"
        >
          Book a Lesson
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero: split layout, Ed's photo/video right -->
  <section class="pt-28 pb-12 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-[1.2fr,1fr] gap-8 lg:gap-8 items-center">
        <div>
          <div class="inline-flex items-center gap-2 glass-card rounded-full px-4 py-2 mb-8">
            <div class="h-2 w-2 rounded-full bg-forest-500 animate-pulse"></div>
            <span class="text-xs font-semibold text-forest-700 uppercase tracking-wider">
              Gateway PGA Teacher of the Year
            </span>
          </div>

          <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold leading-[0.95] tracking-tight mb-6">
            Your game,<br />
            <span class="text-gradient">reimagined.</span>
          </h1>

          <p class="text-lg sm:text-xl text-gray-500 max-w-md mb-10 leading-relaxed">
            Personalized golf instruction from Missouri's #2 ranked teacher.
            Where fundamentals meet modern coaching.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#book"
              class="group inline-flex items-center justify-center rounded-2xl btn-gradient px-8 py-4 text-base font-semibold text-white transition-all hover:shadow-xl hover:shadow-forest-600/25 hover:-translate-y-0.5"
            >
              Book a Lesson
              <svg class="ml-2 h-5 w-5 group-hover:translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </a>
            <a
              href="#about"
              class="inline-flex items-center justify-center rounded-2xl border-2 border-gray-200 px-8 py-4 text-base font-semibold text-forest-800 hover:border-forest-300 transition-all hover:-translate-y-0.5"
            >
              Meet Ed
            </a>
          </div>

          <div class="mt-14 flex gap-10">
            <div>
              <p class="font-display text-3xl font-bold text-forest-700">#2</p>
              <p class="text-xs text-gray-400 mt-1 uppercase tracking-wider">In Missouri</p>
            </div>
            <div class="w-px bg-gray-200"></div>
            <div>
              <p class="font-display text-3xl font-bold text-forest-700">2021</p>
              <p class="text-xs text-gray-400 mt-1 uppercase tracking-wider">PGA TOTY</p>
            </div>
            <div class="w-px bg-gray-200"></div>
            <div>
              <p class="font-display text-3xl font-bold text-forest-700">11+</p>
              <p class="text-xs text-gray-400 mt-1 uppercase tracking-wider">Years</p>
            </div>
          </div>
        </div>

        <!-- Ed's photo/video with floating badges -->
        <div class="relative flex justify-center lg:justify-end">
          <div class="w-full max-w-sm lg:max-w-md relative">
            <!-- Floating badges around the image -->
            <div class="absolute -top-3 -left-3 z-10 glass-card rounded-2xl px-4 py-2.5 shadow-lg" style="animation: float 5s ease-in-out infinite;">
              <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                </svg>
                <span class="text-xs font-bold text-gray-900">#2 in Missouri</span>
              </div>
            </div>
            <div class="absolute -bottom-3 -left-4 z-10 glass-card rounded-2xl px-4 py-2.5 shadow-lg" style="animation: float 7s ease-in-out 1s infinite;">
              <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0 1 16.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.02 6.02 0 0 1-7.54 0" />
                </svg>
                <span class="text-xs font-bold text-gray-900">PGA TOTY 2021</span>
              </div>
            </div>
            <div class="absolute top-1/3 -right-3 z-10 glass-card rounded-2xl px-4 py-2.5 shadow-lg" style="animation: float 6s ease-in-out 0.5s infinite;">
              <div class="flex items-center gap-2">
                <span class="text-xs font-bold text-forest-600">11+</span>
                <span class="text-xs font-bold text-gray-900">Years</span>
              </div>
            </div>

            <div class="animate-float">
              <div class="relative rounded-[28px] overflow-hidden float-shadow">
                <!--
                  FOR IMAGE: <img src="/images/hero.jpg" alt="Ed Schwent" class="w-full aspect-[4/5] object-cover" />
                  FOR VIDEO: <video autoplay muted loop playsinline class="w-full aspect-[4/5] object-cover"><source src="/videos/hero.mp4" type="video/mp4" /></video>
                -->
                <div class="aspect-[4/5] bg-gradient-to-br from-forest-100 via-forest-50 to-white flex items-center justify-center">
                  <div class="text-center">
                    <div class="w-16 h-16 mx-auto rounded-full bg-forest-200/60 flex items-center justify-center mb-3">
                      <svg class="h-8 w-8 text-forest-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0" />
                      </svg>
                    </div>
                    <p class="text-sm text-forest-400 font-medium">Photo or Video</p>
                  </div>
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-4" style="background:rgba(22,101,52,0.75);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);">
                  <p class="text-white font-semibold text-sm">Ed Schwent</p>
                  <p class="text-white/60 text-xs">Head Pro, Old Hickory Golf Club</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About: photo LEFT, content RIGHT (flipped from hero) -->
  <section id="about" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-[35%,1fr] gap-8 lg:gap-10 items-center">
        <!-- Photo first (left on desktop) with floating badges -->
        <div class="relative flex justify-center lg:justify-start">
          <div class="w-full max-w-sm lg:max-w-md relative">
            <!-- Floating badges -->
            <div class="absolute -top-3 -right-3 z-10 glass-card rounded-2xl px-4 py-2.5 shadow-lg" style="animation: float 6s ease-in-out 0.3s infinite;">
              <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342" />
                </svg>
                <span class="text-xs font-bold text-gray-900">SLU Coach</span>
              </div>
            </div>
            <div class="absolute bottom-16 -right-3 z-10 glass-card rounded-2xl px-4 py-2.5 shadow-lg" style="animation: float 5s ease-in-out 1.5s infinite;">
              <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                </svg>
                <span class="text-xs font-bold text-gray-900">All Levels</span>
              </div>
            </div>
            <div class="absolute top-1/2 -left-3 z-10 glass-card rounded-2xl px-4 py-2.5 shadow-lg" style="animation: float 7s ease-in-out 0.8s infinite;">
              <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
                </svg>
                <span class="text-xs font-bold text-gray-900">3 Clubs</span>
              </div>
            </div>

            <div class="rounded-[28px] overflow-hidden float-shadow">
              <!-- TODO: Replace with real photo of Ed -->
              <div class="aspect-[4/5] bg-gradient-to-br from-forest-50 via-white to-forest-50 flex items-center justify-center">
                <div class="text-center">
                  <div class="w-16 h-16 mx-auto rounded-full bg-forest-100 flex items-center justify-center mb-3">
                    <svg class="h-8 w-8 text-forest-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0" />
                    </svg>
                  </div>
                  <p class="text-sm text-forest-300 font-medium">Photo of Ed</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Content (right on desktop): scannable with icons -->
        <div>
          <div class="inline-flex items-center gap-2 glass-card rounded-full px-4 py-2 mb-6">
            <span class="text-xs font-semibold text-forest-700 uppercase tracking-wider">About Ed</span>
          </div>
          <h2 class="font-display text-4xl sm:text-5xl font-bold text-gray-900 mb-8 leading-tight">
            Decades of mastery,<br />
            <span class="text-gradient">one swing at a time.</span>
          </h2>

          <p class="text-gray-500 leading-relaxed text-lg mb-8">
            One of the most respected golf professionals in the St. Louis area. Ed brings decades of experience to every lesson at Old Hickory Golf Club.
          </p>

          <!-- Scannable highlights with icons -->
          <div class="space-y-5">
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-xl bg-forest-50 flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Saint Louis University Coach</p>
                <p class="text-gray-500 text-sm">Former collegiate golf coach with a track record of developing competitive players.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-xl bg-forest-50 flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Golf Digest #2 in Missouri</p>
                <p class="text-gray-500 text-sm">Ranked across seven consecutive editions (2015 to 2022) of Golf Digest's Best Teachers.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-xl bg-forest-50 flex-shrink-0 flex items-center justify-center mt-0.5">
                <svg class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Every Level Welcome</p>
                <p class="text-gray-500 text-sm">From first-time players to competitive golfers chasing a breakthrough. Ed meets you where you are.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Method: entire section inside one big bento with golf course bg -->
  <section id="method" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <!-- Big bento container: golf course bg, gradient solid at top fading to reveal image -->
      <div class="relative rounded-[32px] overflow-hidden">
        <img src="/images/golf-bg.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
        <!-- Gradient: solid dark green top (100% to 70%), then fades to transparent -->
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(20,83,45,1) 0%, rgba(20,83,45,1) 30%, rgba(20,83,45,0.7) 50%, rgba(20,83,45,0) 80%);"></div>

        <div class="relative px-6 sm:px-10 lg:px-14 pt-14 sm:pt-20 pb-10 sm:pb-14">
          <!-- Heading inside the bento, on the solid green area -->
          <div class="text-center mb-14">
            <div class="inline-flex items-center gap-2 rounded-full px-4 py-2 mb-6" style="background:rgba(255,255,255,0.12);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.2);">
              <span class="text-xs font-semibold text-white/90 uppercase tracking-wider">The Method</span>
            </div>
            <h2 class="font-display text-4xl sm:text-5xl font-bold text-white leading-tight">
              Every part of<br />your game, covered.
            </h2>
          </div>

          <!-- Bento grid: tall card left (2 rows), 2 stacked right, then bottom row -->
          <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-4">
            <!-- Full Swing: tall card spanning 2 rows -->
            <div class="group md:row-span-2 rounded-2xl p-7 flex flex-col justify-between" style="background:rgba(255,255,255,0.55);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.4);box-shadow:0 8px 32px rgba(0,0,0,0.08);">
              <div>
                <div class="w-11 h-11 rounded-xl bg-forest-100 flex items-center justify-center mb-5 group-hover:bg-forest-200 transition-colors">
                  <svg class="h-5 w-5 text-forest-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                  </svg>
                </div>
