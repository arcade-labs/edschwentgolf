  <!-- Gallery slider -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var track = document.getElementById('slider-track');
      var prevBtn = document.getElementById('slider-prev');
      var nextBtn = document.getElementById('slider-next');
      var dotsContainer = document.getElementById('slider-dots');
      if (!track || !track.children.length) return;

      var slides = Array.from(track.children);
      var count = slides.length;
      var idx = 0;
      var dragging = false;
      var startX = 0;
      var curTx = 0;
      var prevTx = 0;

      function step() {
        var s = slides[0];
        var g = parseInt(window.getComputedStyle(track).gap) || 16;
        return s.offsetWidth + g;
      }

      function goTo(i) {
        idx = Math.max(0, Math.min(i, count - 1));
        curTx = -idx * step();
        prevTx = curTx;
        track.style.transform = 'translateX(' + curTx + 'px)';
        renderDots();
      }

      function renderDots() {
        if (!dotsContainer) return;
        while (dotsContainer.firstChild) dotsContainer.removeChild(dotsContainer.firstChild);
        for (var i = 0; i < count; i++) {
          var dot = document.createElement('button');
          dot.className = 'w-2 h-2 rounded-full transition-all ' +
            (i === idx ? 'bg-green-600 w-6' : 'bg-gray-300 hover:bg-gray-400');
          dot.setAttribute('aria-label', 'Go to photo ' + (i + 1));
          (function(n) { dot.addEventListener('click', function() { goTo(n); }); })(i);
          dotsContainer.appendChild(dot);
        }
      }

      if (prevBtn) prevBtn.addEventListener('click', function() { goTo(idx - 1); });
      if (nextBtn) nextBtn.addEventListener('click', function() { goTo(idx + 1); });

      function dStart(e) {
        dragging = true;
        startX = e.type.indexOf('mouse') >= 0 ? e.clientX : e.touches[0].clientX;
        track.style.transition = 'none';
      }
      function dMove(e) {
        if (!dragging) return;
        var x = e.type.indexOf('mouse') >= 0 ? e.clientX : e.touches[0].clientX;
        curTx = prevTx + (x - startX);
        track.style.transform = 'translateX(' + curTx + 'px)';
      }
      function dEnd() {
        if (!dragging) return;
        dragging = false;
        track.style.transition = 'transform 0.5s cubic-bezier(0.25,0.1,0.25,1)';
        var moved = curTx - prevTx;
        if (moved < -60) goTo(idx + 1);
        else if (moved > 60) goTo(idx - 1);
        else goTo(idx);
      }

      track.addEventListener('mousedown', dStart);
      track.addEventListener('mousemove', dMove);
      track.addEventListener('mouseup', dEnd);
      track.addEventListener('mouseleave', dEnd);
      track.addEventListener('touchstart', dStart, { passive: true });
      track.addEventListener('touchmove', dMove, { passive: true });
      track.addEventListener('touchend', dEnd);

      renderDots();
    });
  </script>
